################################################################################
# @file .gitignore
# @brief Git ignore patterns for OS kernel project
#
# Prevents build artifacts, temporary files, and IDE artifacts from being
# tracked in version control. This keeps the repository clean and focused
# on source code.
#
# Categories:
#   - Build artifacts (object files, libraries, executables)
#   - Output files (ISO images, binaries, logs)
#   - IDE and editor artifacts
#   - Temporary and cache files
#   - Debug symbols
#   - System files
################################################################################

# ============================================================================
# BUILD ARTIFACTS
# ============================================================================

# Object files (compiled C/C++)
*.o
*.obj
*.a
*.lib
*.so
*.dylib
*.dll

# Compiled assembly
*.asm.o

# Dependency files (generated by compiler)
*.d
*.dep

# ============================================================================
# OUTPUT & DISTRIBUTION
# ============================================================================

# Build output directories
/build/
/dist/
/bin/
/obj/
/out/

# Kernel images and bootable media
*.iso
*.img
*.bin
*.elf
*.exe
*.elf32
*.elf64
dist/

# Compiled kernel images
kernel
kernel.bin
kernel.elf
bootloader.bin

# ============================================================================
# IDE & EDITOR ARTIFACTS
# ============================================================================

# Visual Studio Code
.vscode/
.vscode/**
*.code-workspace

# Visual Studio
.vs/
*.vcxproj.user
*.sln.DotSettings
*.VisualStudio

# JetBrains IDEs (CLion, IntelliJ, etc.)
.idea/
*.iml
*.iws
*.ipr
out/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
.vim/
*.swp
*.swo
*~
.netrwhist

# Emacs
*~
\#*\#
.\#*

# Notepad++
.session

# ============================================================================
# DEBUGGING & PROFILING
# ============================================================================

# GDB debug files
.gdb_history
gdb.log
*.gdb

# Valgrind output
valgrind.log
*.out

# Core dumps
core
core.*
*.core

# ============================================================================
# TEMPORARY FILES
# ============================================================================

# Temporary build files
*.tmp
*.temp
*.bak
*.backup
*.orig

# Logs
*.log
build.log
compile.log
test.log
qemu.log

# QEMU output
qemu_output.txt
qemu_debug.txt

# ============================================================================
# SYSTEM FILES
# ============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# Windows
Thumbs.db
*.lnk
$RECYCLE.BIN/
desktop.ini

# Linux
.cache
.local

# ============================================================================
# DEPENDENCY & PACKAGE MANAGERS
# ============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg

# Node (if using npm for build tools)
node_modules/
npm-debug.log
package-lock.json

# ============================================================================
# DOCUMENTATION BUILD ARTIFACTS
# ============================================================================

# Doxygen
docs/
doxygen_sqlite3.db
html/
latex/
*.pdf

# Sphinx
_build/
.doctrees/

# ============================================================================
# TEST ARTIFACTS
# ============================================================================

# Test executables
test_*
tests/test_*
!tests/test_*.c
!tests/test_*.h
!/tests/test_framework.*

# Test output
test_results.txt
test_report.html
coverage/
*.gcda
*.gcno

# ============================================================================
# CI/CD ARTIFACTS
# ============================================================================

# GitHub Actions
.github/workflows/*.log
.github/workflows/artifacts/

# Travis CI
.travis.yml.local
travis_artifacts/

# GitLab CI
.gitlab-ci.yml.local

# ============================================================================
# COMPRESSION & ARCHIVES
# ============================================================================

*.zip
*.tar
*.tar.gz
*.tar.bz2
*.7z
*.rar

# ============================================================================
# MISC
# ============================================================================

# Compiled Python
*.pyc
*.pyo

# Generated files
*.generated.c
*.generated.h
TAGS
tags
cscope.*

# OS-specific
.env
.env.local
secrets.txt
